<DataTemplate xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:vs="http://schemas.microsoft.com/visualstudio/extensibility/2022/xaml"
              xmlns:styles="clr-namespace:Microsoft.VisualStudio.Shell;assembly=Microsoft.VisualStudio.Shell.15.0"
              xmlns:colors="clr-namespace:Microsoft.VisualStudio.PlatformUI;assembly=Microsoft.VisualStudio.Shell.15.0">
    <Grid Width="400" Height="250" Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>
    
    <!-- Title -->
    <TextBlock Grid.Row="0" 
               Text="{Binding Title}" 
               FontSize="16" 
               FontWeight="SemiBold" 
               Margin="0,0,0,16"
               Foreground="{DynamicResource {x:Static colors:EnvironmentColors.SystemWindowTextBrushKey}}"/>
    
    <!-- Environment Selection Label -->
    <TextBlock Grid.Row="1" 
               Text="请选择环境:" 
               Margin="0,0,0,8"
               Foreground="{DynamicResource {x:Static colors:EnvironmentColors.SystemWindowTextBrushKey}}"/>
    
    <!-- Environment Selection -->
    <ComboBox Grid.Row="2"
              x:Name="EnvironmentComboBox"
              Height="28"
              Margin="0,0,0,16"
              ItemsSource="{Binding EnvironmentOptions}"
              Background="{DynamicResource {x:Static colors:EnvironmentColors.SystemWindowBrushKey}}"
              Foreground="{DynamicResource {x:Static colors:EnvironmentColors.SystemWindowTextBrushKey}}"
              BorderBrush="{DynamicResource {x:Static colors:EnvironmentColors.SystemControlBackgroundChromeMediumBrushKey}}"/>
    
    <!-- Dialog Buttons -->
    <StackPanel Grid.Row="3" 
                Orientation="Horizontal" 
                HorizontalAlignment="Right">
      <Button x:Name="ConfirmButton"
              Content="确认"
              Width="80"
              Height="28"
              Margin="0,0,8,0"
              Background="{DynamicResource {x:Static colors:EnvironmentColors.SystemAccentColorBrushKey}}"
              Foreground="White"
              BorderBrush="{DynamicResource {x:Static colors:EnvironmentColors.SystemAccentColorBrushKey}}"/>
      
      <Button x:Name="CancelButton"
              Content="取消"
              Width="80"
              Height="28"
              Background="{DynamicResource {x:Static colors:EnvironmentColors.SystemControlBackgroundChromeMediumBrushKey}}"
              Foreground="{DynamicResource {x:Static colors:EnvironmentColors.SystemWindowTextBrushKey}}"
              BorderBrush="{DynamicResource {x:Static colors:EnvironmentColors.SystemControlBackgroundChromeMediumBrushKey}}"/>
    </StackPanel>
    </Grid>
</DataTemplate>